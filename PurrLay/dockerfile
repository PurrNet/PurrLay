# Build stage
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy entire solution (context must be solution root)
COPY PurrLay.sln .
COPY PurrLay.Shared/ PurrLay.Shared/
COPY PurrLay.UdpV1/ PurrLay.UdpV1/
COPY PurrLay.UdpV2/ PurrLay.UdpV2/
COPY PurrLay/ PurrLay/

RUN dotnet publish PurrLay/PurrLay.csproj -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app .

ENV HOST=+
ENV PORT=8081

EXPOSE ${PORT}
EXPOSE 7777/udp
EXPOSE 7778/udp

ENTRYPOINT ["dotnet", "PurrLay.dll"]
